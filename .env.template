# Azure Developer CLI environment variables
# Copy to .azure/<env-name>/.env and fill in values

# VM admin credentials
AZURE_ADMIN_USERNAME=azureadmin
AZURE_ADMIN_PASSWORD=

# Active Directory
AZURE_DOMAIN_FQDN=contoso.local
AZURE_DOMAIN_NETBIOS=CONTOSO

# Service accounts (UPN format)
AZURE_SQL_SERVICE_ACCOUNT=sqlservice@contoso.local
AZURE_SQL_SERVICE_PASSWORD=
AZURE_CLUSTER_OPERATOR_ACCOUNT=clusteradmin@contoso.local
AZURE_CLUSTER_OPERATOR_PASSWORD=
AZURE_CLUSTER_BOOTSTRAP_ACCOUNT=clusteradmin@contoso.local
AZURE_CLUSTER_BOOTSTRAP_PASSWORD=

# SQL Server
AZURE_SQL_IMAGE_OFFER=sql2022-ws2022
AZURE_SQL_IMAGE_SKU=Enterprise
